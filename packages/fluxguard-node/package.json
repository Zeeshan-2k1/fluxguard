{
  "name": "fluxguard",
  "version": "0.1.0",
  "description": "Distributed rate limiter for Node.js — Redis-backed with multiple algorithms",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zeeshan-2k1/fluxguard.git"
  },
  "bugs": {
    "url": "https://github.com/Zeeshan-2k1/fluxguard/issues"
  },
  "homepage": "https://github.com/Zeeshan-2k1/fluxguard#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "scripts",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --external ioredis --external prom-client",
    "clean": "rm -rf dist",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration",
    "lint": "eslint src --max-warnings 0"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "prom-client": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@fluxguard/fixtures": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jest": "^29.7.0",
    "prom-client": "^15.1.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "dependencies": {}
}
